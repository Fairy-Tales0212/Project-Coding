{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "D:\\MinGW\\bin\\gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "Source/*.c",
                "-ID:/Project/Tetris/Answer/Code/Header",
                // 关键：强制编译器输出 UTF-8 编码
                "-fexec-charset=UTF-8",
                "-o",
                "${workspaceFolder}/Tetris.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                {
                    "owner": "gcc",
                    "fileLocation": ["relative", "${workspaceFolder}"],
                    "pattern": {
                        "regexp": "^(.*?)(:(\\d+):(\\d+))?:\\s+(error|warning|note):\\s+(.*)$",
                        "file": 1,
                        "line": 3,
                        "column": 4,
                        "severity": 5,
                        "message": 6
                    }
                }
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务"
        }
    ]
}